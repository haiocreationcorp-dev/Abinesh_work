generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AssetCategory {
  CHARACTER
  BACKGROUND
  EXPRESSION
  PROP
  EFFECT
  COSTUME
  BUBBLE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  comics    Comic[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id            String        @id @default(cuid())
  name          String
  category      AssetCategory
  tags          String[]
  filename      String
  filePath      String
  thumbnailPath String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Comic {
  id        String   @id @default(cuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  panels    Panel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Panel data JSON shape:
// {
//   background: { assetId, filePath } | null,
//   characters: [{ instanceId, assetId, filePath, name, position:{x,y}, scale, rotation, flipX, bodyParts:{partId:{rotate}} }],
//   props:      [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   effects:    [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   speechBubbles: [{ instanceId, type, text, position:{x,y}, width, height, tailX, tailY, style:{fillColor,strokeColor,fontSize,fontFamily} }]
// }
model Panel {
  id        String   @id @default(cuid())
  comicId   String
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  order     Int
  layout    String   @default("single")
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([comicId, order])
}
