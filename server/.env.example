PORT=3000
DATABASE_URL="postgresql://postgres:password@localhost:5432/bharath_comic?schema=public"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Razorpay (test mode) — used for institution chief billing
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# SMTP — used for password-reset OTP emails (Admin / Institution Chief / Teacher only;
# Students recover via their teacher, no email required). Any SMTP-capable provider works.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="BharathComic <no-reply@bharathcomic.example>"

# Local Ollama server used for AI spelling/grammar + rewrite suggestions
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Small/fast model used for the on-blur punctuation-only pass
OLLAMA_PUNCT_MODEL=llama3.2:1b
# Custom model (based on llama3.1:8b) tuned for comic-themed alternative phrasing
OLLAMA_REWRITE_MODEL=comic-rewrite
