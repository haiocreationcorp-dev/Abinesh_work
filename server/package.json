{
  "name": "bharath-comic-server",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:backup": "node scripts/backupDb.js",
    "db:export": "node scripts/exportData.js",
    "files:backup": "node scripts/backupUploads.js",
    "env:backup": "node scripts/backupEnv.js",
    "backup:all": "node scripts/backupDb.js && node scripts/exportData.js && node scripts/backupUploads.js && node scripts/backupEnv.js",
    "db:restore:test": "node scripts/restoreDb.js",
    "files:restore:test": "node scripts/restoreUploads.js",
    "test": "node --test src/utils/*.test.js"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "bharath-comic": "file:..",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "prisma": "^5.9.1"
  },
  "allowScripts": {
    "prisma@5.22.0": true,
    "sharp@0.34.5": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true
  }
}
