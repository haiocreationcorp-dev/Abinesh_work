generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  TEACHER
  STUDENT
  INSTITUTION_CHIEF
}

enum BillingPlan {
  QUARTERLY
  YEARLY
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum InstitutionType {
  SCHOOL
  COLLEGE
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetCategory {
  CHARACTER
  BACKGROUND
  EXPRESSION
  PROP
  EFFECT
  COSTUME
  BUBBLE
  SOUND
  BODY_PART
  FACE_PART
  FACE
  DRESS_PART
  DRESS
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  password      String
  role          Role         @default(USER)
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  // School-only registration fields
  gradeLevel    String?      // e.g. "10th" — a school grade level, unrelated to the Class model below
  section       String?      // e.g. "A"
  // College-only registration fields
  department    String?
  year          String?      // e.g. "2nd Year"
  // Shared (school or college)
  rollNo        String?
  comics        Comic[]
  tasksCreated  Task[]
  submissions   Submission[]
  classesCreated Class[]
  enrollments   ClassEnrollment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Institution {
  id                    String          @id @default(cuid())
  name                  String
  code                  String          @unique
  type                  InstitutionType @default(SCHOOL)
  subscriptionStartedAt DateTime?
  subscriptionExpiresAt DateTime?
  suspended             Boolean         @default(false)
  systemCount           Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  users                 User[]
  tasks                 Task[]
  classes               Class[]
  payments              Payment[]
}

// A billing cycle order/charge for an institution's Razorpay subscription payment.
// systemCount/periodStart/periodEnd are snapshotted at order-creation time so payment
// history and the auto-extend-on-verify logic don't depend on re-reading mutable
// Institution state later.
model Payment {
  id                String        @id @default(cuid())
  institutionId     String
  institution       Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  planType          BillingPlan
  systemCount       Int
  amount            Int           // paise (Razorpay's native unit)
  currency          String        @default("INR")
  razorpayOrderId   String        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  status            PaymentStatus @default(CREATED)
  periodStart       DateTime?
  periodEnd         DateTime?
  createdAt         DateTime      @default(now())
  paidAt            DateTime?

  @@index([institutionId])
}

// A teacher's classroom/roster group. Students request to join; the teacher approves/rejects.
model Class {
  id            String            @id @default(cuid())
  name          String
  teacherId     String
  teacher       User              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  enrollments   ClassEnrollment[]
  tasks         Task[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ClassEnrollment {
  id        String           @id @default(cuid())
  classId   String
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    EnrollmentStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([classId, studentId])
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?
  dueDate       DateTime?
  teacherId     String
  teacher       User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  classId       String?      // null = legacy/institution-wide task (preserves pre-Class behavior)
  class         Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions   Submission[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Submission {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  comicId     String
  comic       Comic     @relation(fields: [comicId], references: [id], onDelete: Cascade)
  pdfPath     String
  score       Int?
  feedback    String?
  submittedAt DateTime  @default(now())
  gradedAt    DateTime?

  @@unique([taskId, studentId])
}

model Asset {
  id            String        @id @default(cuid())
  name          String
  category      AssetCategory
  tags          String[]
  filename      String
  filePath      String
  thumbnailPath String?
  layoutPath    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Comic {
  id          String       @id @default(cuid())
  title       String
  userId      String
  pages       Json         @default("[]")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  panels      Panel[]
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Panel data JSON shape:
// {
//   background: { assetId, filePath } | null,
//   characters: [{ instanceId, assetId, filePath, name, position:{x,y}, scale, rotation, flipX, bodyParts:{partId:{rotate}} }],
//   props:      [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   effects:    [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   speechBubbles: [{ instanceId, type, text, position:{x,y}, width, height, tailX, tailY, style:{fillColor,strokeColor,fontSize,fontFamily} }]
// }
model Panel {
  id        String   @id @default(cuid())
  comicId   String
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  order     Int
  layout    String   @default("single")
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([comicId, order])
}

model Pose {
  id        String   @id @default(cuid())
  name      String
  rotations Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Remembers the calibrated position/size/rotation of a face part (hairstyle, nose, etc.)
// on a specific face, so the same face+part pairing can be auto-positioned next time.
model FacePartAlignment {
  id          String   @id @default(cuid())
  faceAssetId String
  partAssetId String
  partType    String
  x           Float
  y           Float
  w           Float
  h           Float
  rotation    Float    @default(0)
  flipX       Boolean  @default(false)
  flipY       Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([faceAssetId, partAssetId, partType])
}

model LightingPreset {
  id          String   @id
  label       String
  icon        String   @default("✨")
  intensity   Int      @default(100)
  temperature Int      @default(0)
  tint        Int      @default(0)
  brightness  Int      @default(0)
  contrast    Int      @default(0)
  highlights  Int      @default(0)
  shadows     Int      @default(0)
  saturation  Int      @default(0)
  vibrance    Int      @default(0)
  bloom       Int      @default(0)
  glow        Int      @default(0)
  blur        Int      @default(0)
  rays        Boolean  @default(false)
  flash       Boolean  @default(false)
  overlayColor      String? // hex color, e.g. "#1e3a8a" — custom tint layer on top of the slider-driven grade
  overlayBlendMode  String  @default("multiply")
  overlayOpacity    Int     @default(0) // 0 = no custom overlay layer
  updatedAt   DateTime @updatedAt
}
