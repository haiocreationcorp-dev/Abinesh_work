generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  TEACHER
  STUDENT
  INSTITUTION_CHIEF
}

enum BillingPlan {
  QUARTERLY
  YEARLY
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum InstitutionType {
  SCHOOL
  COLLEGE
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AssetCategory {
  FACE_PART
  FACE_TEMPLATE
  BODY_POSE
  BACKGROUND
  PROP
  EFFECT
  BUBBLE
  SOUND
}

enum AssetView {
  FRONT
  THREE_QUARTER
}

enum FacePartType {
  FACE_SHAPE
  HAIR
  EYES
  MOUTH
}

enum PoseType {
  P1
  P2
  P3
  P4
  P5
  P6
  P7
  P8
  P9
  P10
  P11
  P12
  P13
  P14
  P15
  P16
  P17
  P18
  P19
  P20
  P21
  P22
  P23
  P24
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  password      String
  role          Role         @default(USER)
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  avatarPath    String?      // profile photo, e.g. "/uploads/avatars/<uuid>.webp"; null = show initial-letter icon
  disabled      Boolean      @default(false) // blocks login when true (checked at login time, not per-request)
  // School-only registration fields
  gradeLevel    String?      // e.g. "10th" — a school grade level, unrelated to the Class model below
  section       String?      // e.g. "A"
  // College-only registration fields
  department    String?
  year          String?      // e.g. "2nd Year"
  // Shared (school or college)
  rollNo        String?
  gender        Gender?
  comics        Comic[]
  tasksCreated  Task[]
  submissions   Submission[]
  classesCreated Class[]
  enrollments   ClassEnrollment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Institution {
  id                    String          @id @default(cuid())
  name                  String
  code                  String          @unique
  type                  InstitutionType @default(SCHOOL)
  subscriptionStartedAt DateTime?
  subscriptionExpiresAt DateTime?
  suspended             Boolean         @default(false)
  systemCount           Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  users                 User[]
  tasks                 Task[]
  classes               Class[]
  payments              Payment[]
}

// A billing cycle order/charge for an institution's Razorpay subscription payment.
// systemCount/periodStart/periodEnd are snapshotted at order-creation time so payment
// history and the auto-extend-on-verify logic don't depend on re-reading mutable
// Institution state later.
model Payment {
  id                String        @id @default(cuid())
  institutionId     String
  institution       Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  planType          BillingPlan
  systemCount       Int
  amount            Int           // paise (Razorpay's native unit)
  currency          String        @default("INR")
  razorpayOrderId   String        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  status            PaymentStatus @default(CREATED)
  periodStart       DateTime?
  periodEnd         DateTime?
  createdAt         DateTime      @default(now())
  paidAt            DateTime?

  @@index([institutionId])
}

// A teacher's classroom/roster group. Students request to join; the teacher approves/rejects.
model Class {
  id            String            @id @default(cuid())
  name          String
  code          String?           @unique // join code, e.g. "AB3X-7KQM"; nullable so the migration is non-destructive — see server/scripts/backfillClassCodes.js
  teacherId     String
  teacher       User              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  enrollments   ClassEnrollment[]
  tasks         Task[]
  aiEnabled     Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ClassEnrollment {
  id        String           @id @default(cuid())
  classId   String
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    EnrollmentStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([classId, studentId])
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?
  dueDate       DateTime?
  teacherId     String
  teacher       User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  classId       String?      // null = legacy/institution-wide task (preserves pre-Class behavior)
  class         Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions   Submission[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Submission {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  comicId     String
  comic       Comic     @relation(fields: [comicId], references: [id], onDelete: Cascade)
  pdfPath     String
  score       Int?
  feedback    String?
  submittedAt DateTime  @default(now())
  gradedAt    DateTime?

  @@unique([taskId, studentId])
}

model Asset {
  id              String        @id @default(cuid())
  name            String
  category        AssetCategory
  tags            String[]
  filename        String
  filePath        String
  thumbnailPath   String?
  layoutPath      String?
  // HSV thresholds ({ hueMin, hueMax, satMin, valMin }) used when this asset's skin
  // tones were normalized at upload time. Null if normalization was never applied.
  // Recorded so the admin's mask-tuning choice for this asset is remembered.
  skinThresholds  Json?
  // Front/3-4 pairing — relevant for FACE_PART, FACE_TEMPLATE, BODY_POSE.
  view            AssetView?
  // FACE_PART only: which of the 4 reusable face pieces this is.
  partType        FacePartType?
  // FACE_PART only, optional.
  gender          String?
  // FACE_PART (partType EYES) only, optional — which of the 5 eye styles this is,
  // tracked separately per Gender (same as other FACE_PART metadata).
  eyeType         String?
  // FACE_PART (partType MOUTH) only, optional — same convention as eyeType.
  mouthType       String?
  // FACE_TEMPLATE only: groups a Front+3/4 pair under one named identity (e.g. "Rahul").
  faceFamily      String?
  // BODY_POSE only: free-text costume name (e.g. "Student", "Police").
  costume         String?
  // BODY_POSE only.
  poseType        PoseType?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Comic {
  id          String       @id @default(cuid())
  title       String
  userId      String
  pages       Json         @default("[]")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  panels      Panel[]
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Panel data JSON shape:
// {
//   background: { assetId, filePath } | null,
//   characters: [{ instanceId, assetId, filePath, name, position:{x,y}, scale, rotation, flipX, bodyParts:{partId:{rotate}} }],
//   props:      [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   effects:    [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   speechBubbles: [{ instanceId, type, text, position:{x,y}, width, height, tailX, tailY, style:{fillColor,strokeColor,fontSize,fontFamily} }]
// }
model Panel {
  id        String   @id @default(cuid())
  comicId   String
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  order     Int
  layout    String   @default("single")
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([comicId, order])
}

model Pose {
  id        String   @id @default(cuid())
  name      String
  rotations Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Remembers the calibrated position/size/rotation of a face part (hairstyle, nose, etc.)
// on a specific face, so the same face+part pairing can be auto-positioned next time.
model FacePartAlignment {
  id          String   @id @default(cuid())
  faceAssetId String
  partAssetId String
  partType    String
  x           Float
  y           Float
  w           Float
  h           Float
  rotation    Float    @default(0)
  flipX       Boolean  @default(false)
  flipY       Boolean  @default(false)
  connectX    Float    @default(0.5)
  connectY    Float    @default(0.0)
  updatedAt   DateTime @updatedAt

  @@unique([faceAssetId, partAssetId, partType])
}

// A reusable eye+mouth combo (e.g. "happy", "angry") that can be swapped onto any
// FACE_TEMPLATE. Position on a given face is resolved via FacePartAlignment, same as any
// other alignable part — this model only holds which two FACE_PART assets make up the look.
model Expression {
  id            String   @id @default(cuid())
  name          String
  eyeAssetId    String
  mouthAssetId  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// A named comic-character identity: which FACE_TEMPLATEs represent it (front and,
// optionally, 3/4) plus its default appearance. Plain string id references (no @relation),
// matching the FacePartAlignment convention — validated at the application layer.
model CharacterPreset {
  id                  String   @id @default(cuid())
  name                String
  frontFaceId         String?
  threeQuarterFaceId  String?
  // Which face to use when the active body pose's own view has no matching face assigned
  // (e.g. pose is Front but only a 3/4 face was set) — 'FRONT' or 'THREE_QUARTER'. Explicit
  // so neither face is silently assumed as "the" default; admin picks it.
  defaultFaceView     String?
  skinTone            String
  hairColor           String
  irisColor           String?
  defaultExpressionId String?
  // BODY_POSE asset (costume+pose baked together) used automatically the first time this
  // character is placed in a panel, instead of forcing a manual pick every time — still
  // freely changeable afterward per-placement via the Outfit/Pose tools, same as today.
  defaultBodyPoseId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LightingPreset {
  id          String   @id
  label       String
  icon        String   @default("✨")
  intensity   Int      @default(100)
  temperature Int      @default(0)
  tint        Int      @default(0)
  brightness  Int      @default(0)
  contrast    Int      @default(0)
  highlights  Int      @default(0)
  shadows     Int      @default(0)
  saturation  Int      @default(0)
  vibrance    Int      @default(0)
  bloom       Int      @default(0)
  glow        Int      @default(0)
  blur        Int      @default(0)
  rays        Boolean  @default(false)
  flash       Boolean  @default(false)
  overlayColor      String? // hex color, e.g. "#1e3a8a" — custom tint layer on top of the slider-driven grade
  overlayBlendMode  String  @default("multiply")
  overlayOpacity    Int     @default(0) // 0 = no custom overlay layer
  updatedAt   DateTime @updatedAt
}
