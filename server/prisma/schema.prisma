generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AssetCategory {
  FACE_PART
  FACE_TEMPLATE
  BODY_POSE
  BACKGROUND
  PROP
  EFFECT
  BUBBLE
  SOUND
}

enum AssetView {
  FRONT
  THREE_QUARTER
}

enum FacePartType {
  FACE_SHAPE
  HAIR
  EYES
  MOUTH
}

enum PoseType {
  STANDING
  WALKING
  RUNNING
  SITTING
  POINTING
  TALKING
  READING
  ARMS_CROSSED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  comics    Comic[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id              String        @id @default(cuid())
  name            String
  category        AssetCategory
  tags            String[]
  filename        String
  filePath        String
  thumbnailPath   String?
  layoutPath      String?
  // HSV thresholds ({ hueMin, hueMax, satMin, valMin }) used when this asset's skin
  // tones were normalized at upload time. Null if normalization was never applied.
  // Recorded so the admin's mask-tuning choice for this asset is remembered.
  skinThresholds  Json?
  // Front/3-4 pairing — relevant for FACE_PART, FACE_TEMPLATE, BODY_POSE.
  view            AssetView?
  // FACE_PART only: which of the 4 reusable face pieces this is.
  partType        FacePartType?
  // FACE_PART only, optional.
  gender          String?
  // FACE_TEMPLATE only: groups a Front+3/4 pair under one named identity (e.g. "Rahul").
  faceFamily      String?
  // BODY_POSE only: free-text costume name (e.g. "Student", "Police").
  costume         String?
  // BODY_POSE only.
  poseType        PoseType?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Comic {
  id        String   @id @default(cuid())
  title     String
  userId    String
  pages     Json     @default("[]")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  panels    Panel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Panel data JSON shape:
// {
//   background: { assetId, filePath } | null,
//   characters: [{ instanceId, assetId, filePath, name, position:{x,y}, scale, rotation, flipX, bodyParts:{partId:{rotate}} }],
//   props:      [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   effects:    [{ instanceId, assetId, filePath, position:{x,y}, scale, rotation }],
//   speechBubbles: [{ instanceId, type, text, position:{x,y}, width, height, tailX, tailY, style:{fillColor,strokeColor,fontSize,fontFamily} }]
// }
model Panel {
  id        String   @id @default(cuid())
  comicId   String
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  order     Int
  layout    String   @default("single")
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([comicId, order])
}

model Pose {
  id        String   @id @default(cuid())
  name      String
  rotations Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Remembers the calibrated position/size/rotation of a face part (hairstyle, nose, etc.)
// on a specific face, so the same face+part pairing can be auto-positioned next time.
model FacePartAlignment {
  id          String   @id @default(cuid())
  faceAssetId String
  partAssetId String
  partType    String
  x           Float
  y           Float
  w           Float
  h           Float
  rotation    Float    @default(0)
  flipX       Boolean  @default(false)
  flipY       Boolean  @default(false)
  connectX    Float    @default(0.5)
  connectY    Float    @default(0.0)
  updatedAt   DateTime @updatedAt

  @@unique([faceAssetId, partAssetId, partType])
}

// A reusable eye+mouth combo (e.g. "happy", "angry") that can be swapped onto any
// FACE_TEMPLATE. Position on a given face is resolved via FacePartAlignment, same as any
// other alignable part — this model only holds which two FACE_PART assets make up the look.
model Expression {
  id            String   @id @default(cuid())
  name          String
  eyeAssetId    String
  mouthAssetId  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// A named comic-character identity: which FACE_TEMPLATEs represent it (front and,
// optionally, 3/4) plus its default appearance. Plain string id references (no @relation),
// matching the FacePartAlignment convention — validated at the application layer.
model CharacterPreset {
  id                  String   @id @default(cuid())
  name                String
  frontFaceId         String
  threeQuarterFaceId  String?
  skinTone            String
  hairColor           String
  irisColor           String?
  defaultExpressionId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LightingPreset {
  id          String   @id
  label       String
  icon        String   @default("✨")
  intensity   Int      @default(100)
  temperature Int      @default(0)
  tint        Int      @default(0)
  brightness  Int      @default(0)
  contrast    Int      @default(0)
  highlights  Int      @default(0)
  shadows     Int      @default(0)
  saturation  Int      @default(0)
  vibrance    Int      @default(0)
  bloom       Int      @default(0)
  glow        Int      @default(0)
  blur        Int      @default(0)
  rays        Boolean  @default(false)
  flash       Boolean  @default(false)
  overlayColor      String? // hex color, e.g. "#1e3a8a" — custom tint layer on top of the slider-driven grade
  overlayBlendMode  String  @default("multiply")
  overlayOpacity    Int     @default(0) // 0 = no custom overlay layer
  updatedAt   DateTime @updatedAt
}
